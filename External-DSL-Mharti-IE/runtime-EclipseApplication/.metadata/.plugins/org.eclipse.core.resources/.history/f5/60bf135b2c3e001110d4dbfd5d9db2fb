Story EnchantedForest
StartNode start {     
    displayText: "You are in an enchanted forest. Magic fills the air and you feel enchanted\n\nYou see 2 roads to go down and some bushes around",
    -> roadChoice
}

ChoiceNode roadChoice {
    choices: [
        ChoiceOption {displayText: "Go down road number 1", 
            -> road1DialogueTalisman with priority 2 with condition: Talisman==1 and Coin==5 or ((Cucumber<10 and Favor>=15) or ((CancanDancers==1))) or Grit==100,
            -> road1DialogueNoTalisman },
        ChoiceOption {displayText: "Go down road number 2 ", 
            -> road2Dialogue },
        ChoiceOption {displayText: "Look in bushes", 
            -> addTalismanSystemStateChange with priority 3 with condition: Talisman==0 ,
            -> addCoinSystemStateChange with priority 3 with condition: Talisman==1 and BushLookup<3,
            -> addPictureSystemStateChange with priority 2 with condition: Talisman==1 and BushLookup<4,
            -> foundNothingSystemStateChange with priority 1 with condition: BushLookup<5 },
        ChoiceOption {displayText: "Impossible choice",
        	-> hardToGetToNode with priority 1 with condition: HardToGetValue==1} 
        	//-> hardToGetToNode with priority 4 with condition: BushLookup>4,
        	//-> hardToGetToNode with priority 2 with condition: BushLookup>2 and Talisman==1, 
        	//-> hardToGetToNode with priority 1 with condition: BushLookup>2 and (Talisman==1 or coind>=10) } 
    ]
}

DialogueNode hardToGetToNode {
	displayText: "How did we get here!?",
	-> furtherDownTheDeadBranch
}

DialogueNode furtherDownTheDeadBranch  {
    displayText: "", 
    -> shieldChoice
} 

DialogueNode notRefferencedNode  {
    displayText: "", 
    -> shieldChoice
} 

SystemStateChangeNode addTalismanSystemStateChange {
    displayText: "You found a Talisman! It looks important!\nAdded the talisman to backpack ",
    Talisman=1, Coin+=10, Cucumber-=1,
    -> roadChoice
}

SystemStateChangeNode addCoinSystemStateChange {
    displayText: "You found some coin! neat...\nAdded 5 coins to backpack!", 
    BushLookup+=1, Coin+=5,
    -> roadChoice
}

SystemStateChangeNode addPictureSystemStateChange {
    displayText: "You found a picture of your mom! aaaw...\nThat goes right in the shoulder pocket  <3 ", 
    BushLookup+=1, PictureOfMom=1,
    -> roadChoice
}

SystemStateChangeNode foundNothingSystemStateChange {
    displayText: "You found nothing...", 
    BushLookup+=1,
    -> roadChoice
}

DialogueNode road2Dialogue {
    displayText: "You find an opening in the forest but wait! It is blocked by a magic Shield!", 
    -> shieldChoice
}



ChoiceNode shieldChoice {
    choices: [
        ChoiceOption {displayText: "Go back to start", 
            -> start},
        ChoiceOption {displayText: "Try to go through",
	        -> goThroughOpeningDialogueSuccess with priority 2 with condition: Talisman==1,
	        -> goThroughOpeningDialogueFail}
    ]
}

DialogueNode goThroughOpeningDialogueSuccess {
    displayText: "You get through to the opening", 
    -> abruptBadEnd
}

DialogueNode goThroughOpeningDialogueFail {
    displayText: "On no you are blocked!", 
    -> shieldChoice
}

DialogueNode road1DialogueNoTalisman {
    displayText: "You encounter a suspicious looking old lady!\n\"Hello dear child\"\n\n\"Do you perhaps want to help an old lady through the forest?", 
    -> movePastWitchChoice
}

DialogueNode road1DialogueTalisman {
    displayText: "You encounter a suspicious looking old lady!\n\"Hello dear child\"\n\n\"You see the witch for who she is", 
    -> movePastWitchChoice
}

ChoiceNode movePastWitchChoice {
    choices: [
        ChoiceOption {displayText: "Go back to start", 
            -> start},
        ChoiceOption {displayText: "Go past her",
             -> walkPastWitch with priority 2 with condition: Talisman==1,
             -> witchBadEnd}
    ]
}

DialogueNode walkPastWitch {
    displayText: "You catch a lurking eye from the old lady as you walk past", 
    -> abruptBadEnd
}

EndNode witchBadEnd {
    displayText: "The witch stabs you, mauls you and absolutely decimates you. You are dead, dead, dead. Any questions?" 
}

EndNode abruptBadEnd {
    displayText: "Oops... The story ended abruptly.. To be continued maybe?..." 
}